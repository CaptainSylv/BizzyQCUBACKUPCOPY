@* =============================================
    Views/Products/Pchild.cshtml
    Child view â€” inherits _Layout.cshtml (navbar, footer)
    Example data is hardcoded for display/testing purposes.
    Replace with @model binding when the ViewModel is ready.
    ============================================= *@

@* Section: page-specific CSS (linked in <head> via _Layout's @RenderSection("Styles")) *@
@section Styles {
    <link rel="stylesheet" href="~/Content/Pchild.css">
}

@* â”€â”€â”€ Example / Hardcoded Data â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
       TODO: Remove these variables and replace with @model binding.
       e.g. @model BizzyQCU.Models.ProductDetailViewModel
       Then use @Model.ProductName, @Model.Price, etc.
    â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ *@
@{
    var productName = "Pasta Verde";
    var productPrice = "67.00";
    var prepTime = "17";
    var deliveryOptions = "Pickup or Room to Room";
    var productId = "101";

    var enterpriseName = "QCU Enterprise";
    var enterpriseId = "5";
    var isOnline = true;
}

@* â”€â”€â”€ Page Content â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ *@
<div class="checkout-bg">

    @* â”€â”€ Product Card â”€â”€ *@
    <div class="product-card">

        @* Product Image â€” TODO: Replace src with @Model.ImageUrl once wired up *@
        <div class="product-img-wrap">
            <img src="https://placehold.co/320x320?text=Product+Image"
                 alt="@productName" />
        </div>

        @* Product Details *@
        <div class="product-info">

            <h1 class="product-title">@productName</h1>

            <p class="product-price">&#8369;@productPrice</p>

            <p class="product-meta">
                Preparation time: @prepTime min/s <br />
                Delivery: @deliveryOptions
            </p>

            @* Quantity Row *@
            <div class="quantity-row">
                <span class="quantity-label">Quantity</span>
                <div class="qty-controls">
                    <button class="qty-btn" id="btnMinus" type="button" aria-label="Decrease quantity">-</button>
                    <input class="qty-input" id="qtyInput" type="number"
                           value="1" min="1" aria-label="Quantity" />
                    <button class="qty-btn" id="btnPlus" type="button" aria-label="Increase quantity">+</button>
                </div>
            </div>

            @* Hidden inputs â€” read by Pchild.js for AJAX POST *@
            <input type="hidden" id="productId" value="@productId" />

            @* Anti-forgery token for secure AJAX requests *@
            @Html.AntiForgeryToken()

            @* Order Button *@
            <button class="btn-order" id="btnOrder" type="button">
                Order Now
            </button>

        </div>
    </div>

    @* â”€â”€ Enterprise Card â”€â”€ *@
    <div class="enterprise-card">

        @* Avatar â€” TODO: Replace placeholder with @Model.EnterpriseAvatarUrl *@
        <div class="enterprise-avatar">
            <span class="avatar-placeholder">&#128100;</span>
        </div>

        <div class="enterprise-info">
            <p class="enterprise-name">@enterpriseName</p>
            <p class="enterprise-status">
                <span class="status-dot @(isOnline ? "online" : "offline")"></span>
                @(isOnline ? "Online" : "Offline")
            </p>
            <button class="btn-view-enterprise"
                    id="btnViewEnterprise"
                    data-enterprise-id="@enterpriseId"
                    type="button">
                View Enterprise
            </button>
        </div>

    </div>

</div>

@* â”€â”€ Toast Notification (hidden by default, shown via JS) â”€â”€ *@
<div class="checkout-toast" id="checkoutToast" role="status" aria-live="polite"></div>

@* Section: page-specific JS (rendered before </body> via _Layout's @RenderSection("Scripts")) *@
@section Scripts {
    <script src="~/Scripts/Pchild.js"></script>
}

